# ============================================================
# HyperCode V2.4 — .env.example
# ============================================================
# Copy to .env and fill in NON-SECRET values only.
# Secrets (passwords, tokens, keys) → use Docker secrets instead.
# Run: bash scripts/secrets-init.sh
# ============================================================

# ── Paths ───────────────────────────────────────────────────
HC_DATA_ROOT=/mnt/d/hypercode-data

# ── Environment ─────────────────────────────────────────────
ENVIRONMENT=development

# ── Database (non-secret config) ────────────────────────────
POSTGRES_USER=postgres
POSTGRES_DB=hypercode
# POSTGRES_PASSWORD → secrets/postgres_password.txt ✅

# ── Redis ───────────────────────────────────────────────────
HYPERCODE_REDIS_URL=redis://redis:6379/0

# ── BROskiPets (Phase 0) ────────────────────────────────────
BROSKIE_PETS_ENABLED=true
PETS_REDIS_DB=3

# ── CORS ────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:8088,http://127.0.0.1:8088,http://localhost:3000

# ── Observability ───────────────────────────────────────────
PROMETHEUS_RETENTION=30d
PROMETHEUS_RETENTION_SIZE=10GB
OTLP_EXPORTER_DISABLED=false
# GF_SECURITY_ADMIN_PASSWORD → secrets/grafana_admin_password.txt ✅
GF_SECURITY_ADMIN_USER=admin

# ── Ollama ──────────────────────────────────────────────────
OLLAMA_MODEL=qwen2.5-coder:3b

# ── Orchestration ───────────────────────────────────────────
ORCHESTRATOR_ENABLED_AGENTS=
SMOKE_ENDPOINT_ENABLED=false
SMOKE_KEY_ALLOWLIST=
SMOKE_KEY_TTL_SECONDS=900

# ── Mission System ──────────────────────────────────────────
MISSION_CONTROL_URL=
COURSE_SYNC_SECRET=
SHOP_SYNC_SECRET=

# ── Alerts (optional) ───────────────────────────────────────
SLACK_WEBHOOK_URL=
PD_ROUTING_KEY=

# ── Discord ─────────────────────────────────────────────────
DISCORD_GUILD_ID=YOUR_GUILD_ID_HERE
# DISCORD_TOKEN → secrets/discord_token.txt ✅

# ── External APIs ───────────────────────────────────────────
# OPENAI_API_KEY       → secrets/openai_api_key.txt ✅
# PERPLEXITY_API_KEY   → secrets/perplexity_api_key.txt ✅
# API_KEY              → secrets/api_key.txt ✅
# HYPERCODE_JWT_SECRET → secrets/jwt_secret.txt ✅
# ORCHESTRATOR_API_KEY → secrets/orchestrator_api_key.txt ✅
# MINIO_ROOT_USER      → secrets/minio_root_user.txt ✅
# MINIO_ROOT_PASSWORD  → secrets/minio_root_password.txt ✅
# HYPERCODE_MEMORY_KEY → secrets/memory_key.txt ✅
