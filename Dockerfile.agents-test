# Dockerfile.agents-test
# Runs the full test suite in an isolated container.
# Usage:
#   docker build -f Dockerfile.agents-test -t agents-test .
#   docker run --rm agents-test

FROM python:3.14-slim

# Keep Python output unbuffered so pytest output streams in real-time
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

# Hardening: run tests as non-root (reduces blast radius if a test dependency is compromised)
RUN groupadd -r app && useradd -r -g app app

# Install deps first — separate layer so rebuilds are fast when only code changes
COPY tests/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy test files and dependencies
COPY tests/unit/ tests/unit/
COPY src/ src/
COPY agents/ agents/
COPY backend/ backend/

# Drop privileges for test execution
USER app

# Default: run all unit tests
CMD ["python", "-m", "pytest", "tests/unit/", "-v", "--tb=short"]
