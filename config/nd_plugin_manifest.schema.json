{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HyperCode ND Plugin Manifest",
  "description": "Manifest contract for neurodivergent-safe MCP plugins (tool servers).",
  "type": "object",
  "properties": {
    "manifest_version": {
      "type": "integer",
      "enum": [1],
      "default": 1,
      "description": "Schema version for forward compatibility."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Unique plugin name."
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Plugin version (SemVer recommended)."
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "description": "Plugin author or org."
    },
    "nd_metadata": {
      "type": "object",
      "description": "Neurodivergent safety and accessibility metadata.",
      "properties": {
        "cognitive_load": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Expected cognitive demand of the plugin."
        },
        "distraction_level": {
          "type": "string",
          "enum": ["minimal", "moderate", "high"],
          "description": "How attention-grabbing the plugin is."
        },
        "supports_reduced_motion": {
          "type": "boolean",
          "description": "Respects reduced motion preferences."
        },
        "keyboard_navigable": {
          "type": "boolean",
          "description": "All interactions are keyboard accessible."
        },
        "screen_reader_tested": {
          "type": "boolean",
          "description": "Explicitly tested with a screen reader."
        },
        "sensory_profile_aware": {
          "type": "boolean",
          "description": "Adjusts output based on sensory profile when available."
        }
      },
      "required": [
        "cognitive_load",
        "distraction_level",
        "supports_reduced_motion",
        "keyboard_navigable",
        "screen_reader_tested",
        "sensory_profile_aware"
      ],
      "additionalProperties": false
    },
    "tools": {
      "type": "array",
      "description": "Tools exposed by the plugin via /mcp/tools.",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "parameters": {
            "type": "object",
            "description": "JSON Schema for tool parameters (object schema).",
            "properties": {
              "type": {
                "type": "string",
                "const": "object"
              },
              "properties": {
                "type": "object"
              },
              "required": {
                "type": "array",
                "items": { "type": "string" }
              },
              "additionalProperties": {
                "type": "boolean"
              }
            },
            "required": ["type"],
            "additionalProperties": true
          }
        },
        "required": ["name", "description", "parameters"],
        "additionalProperties": false
      }
    }
  },
  "required": ["name", "version", "author", "nd_metadata", "tools"],
  "additionalProperties": false
}

