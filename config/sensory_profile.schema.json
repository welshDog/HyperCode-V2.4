{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HyperCode Sensory Profile",
  "description": "User sensory/accessibility preferences for HyperCode V2.0",
  "type": "object",
  "properties": {
    "theme": {
      "type": "string",
      "enum": ["calm", "focus", "energise"],
      "default": "focus",
      "description": "Active sensory theme preset"
    },
    "motion": {
      "type": "string",
      "enum": ["full", "reduced", "none"],
      "default": "reduced",
      "description": "Animation/transition preference"
    },
    "font": {
      "type": "string",
      "enum": ["default", "opendyslexic", "lexie", "atkinson"],
      "default": "default",
      "description": "Body font override for dyslexia support"
    },
    "contrast": {
      "type": "string",
      "enum": ["normal", "high", "maximum"],
      "default": "normal",
      "description": "Colour contrast level"
    },
    "colour_saturation": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 2.0,
      "default": 1.0,
      "description": "Global colour saturation multiplier (0 = greyscale, 2 = vivid)"
    },
    "letter_spacing": {
      "type": "string",
      "enum": ["normal", "wide", "wider"],
      "default": "normal",
      "description": "Letter spacing preset for readability"
    },
    "line_height": {
      "type": "number",
      "minimum": 1.0,
      "maximum": 3.0,
      "default": 1.6,
      "description": "Line height multiplier"
    }
  },
  "required": ["theme"],
  "additionalProperties": false
}
