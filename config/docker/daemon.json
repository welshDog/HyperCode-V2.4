# Docker Daemon Configuration for HyperCode V2.0
# Place this in C:\Users\<User>\.docker\daemon.json (Windows) or /etc/docker/daemon.json (Linux)

{
  "live-restore": true,
  "log-driver": "json-file",
  "log-opts": {
    "max-size": "10m",
    "max-file": "3"
  },
  "metrics-addr": "0.0.0.0:9323",
  "experimental": true,
  "features": {
    "buildkit": true
  }
}
