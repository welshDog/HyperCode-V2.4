{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.2.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": {
    "list": [
      {
        "name": "Annotations & Alerts",
        "datasource": { "type": "datasource", "uid": "grafana" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "type": "dashboard"
      }
    ]
  },
  "description": "Gordon Tier 3 — Live view of SQLAlchemy connection-pool health and Celery queue throughput. Spot pool exhaustion, queue backlogs, and task failures before they bite.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "HyperHealth Overview",
      "type": "dashboards",
      "tags": ["hyperhealth"],
      "icon": "external link"
    }
  ],
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "🎯 At-a-Glance — KPIs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "🔌 DB Pool Utilisation (sync)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "description": "Sync pool checked_out ÷ (size + max_overflow). Above 80% = back-pressure imminent.",
      "targets": [
        {
          "expr": "100 * hypercode_db_pool_checked_out{engine=\"sync\"} / (hypercode_db_pool_size{engine=\"sync\"} + 20)",
          "legendFormat": "% used",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 80 },
              { "color": "red",    "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "🔌 DB Pool Utilisation (async)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "description": "Async asyncpg pool. Same alert thresholds as sync.",
      "targets": [
        {
          "expr": "100 * hypercode_db_pool_checked_out{engine=\"async\"} / (hypercode_db_pool_size{engine=\"async\"} + 20)",
          "legendFormat": "% used",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 80 },
              { "color": "red",    "value": 95 }
            ]
          },
          "noValue": "0"
        }
      }
    },
    {
      "id": 3,
      "title": "📥 Queue Backlog (pending)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "description": "Total pending Celery tasks across high/normal/low (excludes DLQ). Sustained > 50 = workers can't keep up.",
      "targets": [
        {
          "expr": "sum(hypercode_celery_queue_depth{queue!=\"hypercode-dlq\"})",
          "legendFormat": "pending",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "orange", "value": 50 },
              { "color": "red",    "value": 200 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "💥 Task Failure Rate (5m)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "description": "Failed task ratio over the last 5 minutes (failures ÷ attempts). > 1% = investigate.",
      "targets": [
        {
          "expr": "100 * sum(rate(hypercode_celery_tasks_total{status=\"failure\"}[5m])) / clamp_min(sum(rate(hypercode_celery_tasks_total[5m])), 0.0001)",
          "legendFormat": "% failed",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 5 },
              { "color": "red",    "value": 10 }
            ]
          },
          "noValue": "0"
        }
      }
    },

    {
      "id": 200,
      "type": "row",
      "title": "💧 Connection Pool Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "title": "Sync Pool — Connections in Flight",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "description": "Stacked view: idle (checked_in) + active (checked_out) + overflow connections vs configured pool size.",
      "targets": [
        {
          "expr": "hypercode_db_pool_checked_in{engine=\"sync\"}",
          "legendFormat": "idle (checked_in)",
          "refId": "A"
        },
        {
          "expr": "hypercode_db_pool_checked_out{engine=\"sync\"}",
          "legendFormat": "active (checked_out)",
          "refId": "B"
        },
        {
          "expr": "clamp_min(hypercode_db_pool_overflow{engine=\"sync\"}, 0)",
          "legendFormat": "overflow",
          "refId": "C"
        },
        {
          "expr": "hypercode_db_pool_size{engine=\"sync\"} + 20",
          "legendFormat": "ceiling (size + max_overflow)",
          "refId": "D"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 25,
            "stacking": { "mode": "normal", "group": "A" },
            "lineWidth": 1
          },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ceiling (size + max_overflow)" },
            "properties": [
              { "id": "custom.stacking", "value": { "mode": "none" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "title": "Async Pool — Connections in Flight",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "description": "Native asyncpg pool. Routes hit this via get_async_db().",
      "targets": [
        {
          "expr": "hypercode_db_pool_checked_in{engine=\"async\"}",
          "legendFormat": "idle (checked_in)",
          "refId": "A"
        },
        {
          "expr": "hypercode_db_pool_checked_out{engine=\"async\"}",
          "legendFormat": "active (checked_out)",
          "refId": "B"
        },
        {
          "expr": "clamp_min(hypercode_db_pool_overflow{engine=\"async\"}, 0)",
          "legendFormat": "overflow",
          "refId": "C"
        },
        {
          "expr": "hypercode_db_pool_size{engine=\"async\"} + 20",
          "legendFormat": "ceiling (size + max_overflow)",
          "refId": "D"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 25,
            "stacking": { "mode": "normal", "group": "A" },
            "lineWidth": 1
          },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ceiling (size + max_overflow)" },
            "properties": [
              { "id": "custom.stacking", "value": { "mode": "none" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      }
    },

    {
      "id": 300,
      "type": "row",
      "title": "📨 Celery Queue Throughput",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "title": "Queue Depth by Queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "description": "Pending tasks per queue (Redis LLEN). A queue trending up means workers are losing the race.",
      "targets": [
        {
          "expr": "hypercode_celery_queue_depth",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max", "mean"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 4
          },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 8,
      "title": "Task Throughput by Status (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "description": "Per-second task completion rates broken down by final status.",
      "targets": [
        {
          "expr": "sum by (status) (rate(hypercode_celery_tasks_total[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max", "mean"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "stacking": { "mode": "normal", "group": "A" },
            "lineWidth": 1
          },
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "success" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "failure" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "retry" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      }
    },

    {
      "id": 350,
      "type": "row",
      "title": "🪦 Dead Letter Queue",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "title": "DLQ Depth",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "description": "Tasks that exhausted all retries. Inspect with: redis-cli LRANGE hypercode-dlq 0 -1",
      "targets": [
        {
          "expr": "hypercode_celery_queue_depth{queue=\"hypercode-dlq\"}",
          "legendFormat": "envelopes",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red",    "value": 50 }
            ]
          },
          "noValue": "0"
        }
      }
    },
    {
      "id": 12,
      "title": "DLQ Growth (last 1h)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "description": "DLQ depth over time. A flat line at 0 is healthy. Rising line = active regression.",
      "targets": [
        {
          "expr": "hypercode_celery_queue_depth{queue=\"hypercode-dlq\"}",
          "legendFormat": "DLQ depth",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 30,
            "lineWidth": 2,
            "pointSize": 5
          },
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "id": 400,
      "type": "row",
      "title": "⏱️ Task Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "title": "Task Duration — p50 / p95 / p99 by Task",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 14, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "description": "Latency percentiles per task name. p99 spikes near the 300s soft limit = imminent timeouts.",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, task) (rate(hypercode_celery_task_duration_seconds_bucket[5m])))",
          "legendFormat": "{{task}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, task) (rate(hypercode_celery_task_duration_seconds_bucket[5m])))",
          "legendFormat": "{{task}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, task) (rate(hypercode_celery_task_duration_seconds_bucket[5m])))",
          "legendFormat": "{{task}} p99",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 5,
            "lineWidth": 1
          },
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 60 },
              { "color": "red",    "value": 240 }
            ]
          },
          "custom.thresholdsStyle": { "mode": "dashed" }
        }
      }
    },
    {
      "id": 10,
      "title": "Task Duration Heatmap (all tasks)",
      "type": "heatmap",
      "gridPos": { "h": 9, "w": 10, "x": 14, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "description": "Density of task durations over time. Bright bands at the top = slow tasks accumulating.",
      "targets": [
        {
          "expr": "sum by (le) (rate(hypercode_celery_task_duration_seconds_bucket[1m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": { "axisPlacement": "left", "unit": "s", "decimals": 1 },
        "color": { "mode": "scheme", "scheme": "Turbo", "steps": 64, "exponent": 0.5 },
        "cellGap": 1,
        "tooltip": { "show": true, "yHistogram": true },
        "legend": { "show": true }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "scaleDistribution": { "type": "linear" } }
        }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["hypercode", "tier3", "pools", "queues", "celery", "db"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "timezone": "browser",
  "title": "🚀 HyperCode Tier 3 — Pools & Queues",
  "uid": "hypercode-tier3-pools-queues",
  "version": 1,
  "weekStart": ""
}
