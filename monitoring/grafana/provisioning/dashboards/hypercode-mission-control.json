{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "HyperCode V2.4 — Full system visibility in one view. Container health, agent uptime, request rates, errors, memory, CPU.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "id": 100,
      "title": "⚡ At-a-Glance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },

    {
      "id": 1,
      "title": "🟢 Services Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "targets": [
        {
          "expr": "count(up == 1)",
          "legendFormat": "UP",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "green",  "value": 10 }
            ]
          },
          "unit": "none"
        }
      }
    },

    {
      "id": 2,
      "title": "🔴 Services Down",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "targets": [
        {
          "expr": "count(up == 0) OR vector(0)",
          "legendFormat": "DOWN",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 2 }
            ]
          },
          "unit": "none"
        }
      }
    },

    {
      "id": 3,
      "title": "📈 Requests / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) * 60",
          "legendFormat": "req/min",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",  "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "none",
          "decimals": 0
        }
      }
    },

    {
      "id": 4,
      "title": "🚨 Error Rate %",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100",
          "legendFormat": "error %",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 5 }
            ]
          },
          "unit": "percent",
          "decimals": 2
        }
      }
    },

    {
      "collapsed": false,
      "id": 101,
      "title": "🐳 Service Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },

    {
      "id": 10,
      "title": "🐳 All Services — Up / Down",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{job}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "sortBy": [{ "desc": true, "displayName": "Value" }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Status" },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "mappings", "value": [
                  { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
                  { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "job" },
            "properties": [
              { "id": "displayName", "value": "Service" }
            ]
          }
        ]
      },
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "organize", "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true },
            "renameByName": { "job": "Service", "Value": "Status" }
          }
        }
      ]
    },

    {
      "collapsed": false,
      "id": 102,
      "title": "📊 Traffic",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },

    {
      "id": 20,
      "title": "📈 HTTP Request Rate — by Handler",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_requests_total[2m]))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },

    {
      "id": 21,
      "title": "🚨 Error Rate — 5xx per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_requests_total{status_code=~\"5..\"}[2m]))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      }
    },

    {
      "collapsed": false,
      "id": 103,
      "title": "⏱️ Response Times",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }
    },

    {
      "id": 30,
      "title": "⏱️ P50 / P95 / P99 Response Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red",    "value": 0.5 }
            ]
          }
        }
      }
    },

    {
      "id": 31,
      "title": "⏱️ P99 Response Time — by Handler",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (handler, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },

    {
      "collapsed": false,
      "id": 104,
      "title": "💾 Resources",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }
    },

    {
      "id": 40,
      "title": "💾 Memory — Top Containers",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "targets": [
        {
          "expr": "topk(10, container_memory_working_set_bytes{name=~\"hypercode.*\", name!=\"\"})",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 536870912 },
              { "color": "red",    "value": 1073741824 }
            ]
          }
        }
      }
    },

    {
      "id": 41,
      "title": "⚙️ CPU Usage % — Top Containers",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "targets": [
        {
          "expr": "topk(10, rate(container_cpu_usage_seconds_total{name=~\"hypercode.*\", name!=\"\"}[2m]) * 100)",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red",    "value": 90 }
            ]
          }
        }
      }
    },

    {
      "collapsed": false,
      "id": 105,
      "title": "🤖 Agent Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 }
    },

    {
      "id": 50,
      "title": "🤖 Agent Uptime — Current Status",
      "type": "table",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "targets": [
        {
          "expr": "up{job=~\"agent.*|healer.*|crew.*|broski.*|hyper-arch.*|hyper-obs.*|hyper-work.*|hyper-shield.*|hyper-sweep.*\"}",
          "legendFormat": "{{job}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "sortBy": [{ "desc": false, "displayName": "Value" }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Status" },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "mappings", "value": [
                  { "type": "value", "options": { "0": { "text": "🔴 DOWN", "color": "red" } } },
                  { "type": "value", "options": { "1": { "text": "🟢 UP",   "color": "green" } } }
                ]
              }
            ]
          }
        ]
      },
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "organize", "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true },
            "renameByName": { "job": "Agent", "Value": "Status" }
          }
        }
      ]
    },

    {
      "id": 51,
      "title": "🟢 Agents Currently Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "targets": [
        {
          "expr": "count(up{job=~\"agent.*|healer.*|crew.*|broski.*|hyper-arch.*|hyper-obs.*|hyper-work.*\"} == 1) OR vector(0)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "green",  "value": 6 }
            ]
          }
        }
      }
    },

    {
      "id": 52,
      "title": "🔴 Agents Down",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "targets": [
        {
          "expr": "count(up{job=~\"agent.*|healer.*|crew.*|broski.*|hyper-arch.*|hyper-obs.*|hyper-work.*\"} == 0) OR vector(0)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 2 }
            ]
          }
        }
      }
    },

    {
      "id": 53,
      "title": "📋 Live Logs — hypercode-core",
      "type": "logs",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 46 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\"hypercode-core.*\"} |= `` | line_format \"{{.msg}}\"",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },

    {
      "collapsed": false,
      "id": 106,
      "title": "🔒 Circuit Breakers",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 }
    },

    {
      "id": 60,
      "title": "🔒 Circuit Breaker — Open Circuits",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 51 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "targets": [
        {
          "expr": "count(circuit_breaker_state == 1) OR vector(0)",
          "legendFormat": "OPEN",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 2 }
            ]
          }
        }
      }
    },

    {
      "id": 61,
      "title": "🔒 Circuit Breaker State — History",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 18, "x": 6, "y": 51 },
      "datasource": { "type": "prometheus", "uid": "P1809F7CD0C75ACF3" },
      "targets": [
        {
          "expr": "circuit_breaker_state",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED" } } },
            { "type": "value", "options": { "1": { "text": "OPEN" } } },
            { "type": "value", "options": { "2": { "text": "HALF-OPEN" } } }
          ]
        }
      }
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["hypercode", "mission-control", "v2.4"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "🚀 HyperCode Mission Control",
  "uid": "hypercode-mission-control",
  "version": 1
}
