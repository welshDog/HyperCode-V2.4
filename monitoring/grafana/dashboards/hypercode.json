{
  "title": "HyperCode V2.4 — API Dashboard",
  "uid": "hypercode-api",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Total Requests",
      "type": "stat",
      "targets": [{"expr": "sum(hypercode_http_requests_total)", "legendFormat": "Total"}],
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "targets": [{"expr": "rate(hypercode_http_requests_total[1m])", "legendFormat": "{{method}} {{endpoint}}"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
    },
    {
      "id": 3,
      "title": "P95 Latency (s)",
      "type": "timeseries",
      "targets": [{"expr": "histogram_quantile(0.95, rate(hypercode_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95 {{endpoint}}"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
    },
    {
      "id": 4,
      "title": "Error Rate",
      "type": "timeseries",
      "targets": [{"expr": "rate(hypercode_http_requests_total{status_code=~\"5..\"}[1m])", "legendFormat": "5xx errors"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12}
    }
  ]
}
