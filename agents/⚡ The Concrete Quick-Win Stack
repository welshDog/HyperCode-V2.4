Step 1 — Universal docker-compose for all 22 agents
Drop this in your repo root as docker-compose.agents.yml:

text
# docker-compose.agents.yml — HyperCode V2.0 Full Agent Stack
# Run: docker compose -f docker-compose.agents.yml up -d

version: "3.9"

networks:
  hypercode-net:
    driver: bridge

volumes:
  postgres-data:
  redis-data:

services:

  # ── INFRA ──────────────────────────────────────────────────
  redis:
    image: redis:7-alpine
    restart: unless-stopped
    networks: [hypercode-net]
    volumes: [redis-data:/data]
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      retries: 3

  postgres:
    image: postgres:16-alpine
    restart: unless-stopped
    networks: [hypercode-net]
    volumes: [postgres-data:/var/lib/postgresql/data]
    environment:
      POSTGRES_DB: hypercode
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER}"]
      interval: 10s
      retries: 5

  # ── CORE AGENTS ───────────────────────────────────────────
  healer:
    build: ./agents/healer
    restart: always          # 🩺 ALWAYS — cannot die
    ports: ["8008:8008"]
    networks: [hypercode-net]
    depends_on:
      redis: {condition: service_healthy}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8008/health"]
      interval: 15s
      retries: 3
    environment:
      REDIS_URL: redis://redis:6379
      POSTGRES_URL: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres/hypercode

  architect:
    build: ./agents/architect
    restart: unless-stopped
    ports: ["8080:8080"]
    networks: [hypercode-net]
    depends_on:
      healer: {condition: service_healthy}
    environment:
      REDIS_URL: redis://redis:6379
      DOCKER_HOST: unix:///var/run/docker.sock
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock  # Agent X needs Docker access

  crew-orchestrator:
    build: ./agents/crew-orchestrator
    restart: unless-stopped
    ports: ["8081:8081"]
    networks: [hypercode-net]
    depends_on:
      redis: {condition: service_healthy}
      postgres: {condition: service_healthy}
    environment:
      REDIS_URL: redis://redis:6379
      POSTGRES_URL: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres/hypercode

  memory:
    build: ./agents/memory
    restart: unless-stopped
    ports: ["8082:8082"]
    networks: [hypercode-net]
    depends_on:
      redis: {condition: service_healthy}
      postgres: {condition: service_healthy}

  # ── SPECIALIST AGENTS ─────────────────────────────────────
  frontend-specialist:
    build: ./agents/01-frontend-specialist
    restart: unless-stopped
    networks: [hypercode-net]
    depends_on: [crew-orchestrator]

  backend-specialist:
    build: ./agents/02-backend-specialist
    restart: unless-stopped
    networks: [hypercode-net]
    depends_on: [crew-orchestrator]

  database-architect:
    build: ./agents/03-database-architect
    restart: unless-stopped
    networks: [hypercode-net]
    depends_on:
      postgres: {condition: service_healthy}

  qa-engineer:
    build: ./agents/04-qa-engineer
    restart: unless-stopped
    networks: [hypercode-net]
    depends_on: [crew-orchestrator]

  devops-engineer:
    build: ./agents/05-devops-engineer
    restart: unless-stopped
    networks: [hypercode-net]
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock

  security-engineer:
    build: ./agents/06-security-engineer
    restart: unless-stopped
    networks: [hypercode-net]

  system-architect:
    build: ./agents/07-system-architect
    restart: unless-stopped
    networks: [hypercode-net]
    depends_on: [architect]

  project-strategist:
    build: ./agents/08-project-strategist
    restart: unless-stopped
    networks: [hypercode-net]
    depends_on: [crew-orchestrator]

  tips-writer:
    build: ./agents/09-tips-tricks-writer
    restart: unless-stopped
    networks: [hypercode-net]

  # ── INTERFACE LAYER ───────────────────────────────────────
  broski-terminal:
    build: ./agents/broski-bot
    restart: unless-stopped
    ports: ["3000:3000"]
    networks: [hypercode-net]
    environment:
      DISCORD_TOKEN: ${DISCORD_TOKEN}

  dashboard:
    build: ./agents/dashboard
    restart: unless-stopped
    ports: ["8088:8088"]
    networks: [hypercode-net]
    depends_on: [crew-orchestrator, memory]

  # ── OBSERVABILITY ─────────────────────────────────────────
  grafana:
    image: grafana/grafana:latest
    restart: unless-stopped
    ports: ["3001:3000"]
    networks: [hypercode-net]
    environment:
      GF_SECURITY_ADMIN_PASSWORD: ${GRAFANA_PASSWORD:-admin}
Step 2 — Universal Dockerfile every agent inherits
Save as agents/base-agent/Dockerfile:

text
# agents/base-agent/Dockerfile
# Every Hyper Agent extends FROM this

FROM python:3.12-slim

# Non-root user — security hardening ✅
RUN groupadd -r hyper && useradd -r -g hyper hyper

WORKDIR /app

# Deps first (layer cache wins)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .
RUN chown -R hyper:hyper /app

USER hyper

# Health endpoint MUST exist — non-negotiable
HEALTHCHECK --interval=15s --timeout=3s --retries=3 \
  CMD curl -f http://localhost:${PORT:-8000}/health || exit 1

CMD ["python", "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
Then each agent's own Dockerfile is just:

text
# agents/02-backend-specialist/Dockerfile
FROM hypercode/base-agent:2.0.0
# Agent-specific overrides only
ENV PORT=8002
ENV AGENT_NAME=backend-specialist
Step 3 — Health + Identity contract (every agent must have this)
Add to every main.py — takes 10 minutes per agent:
​

python
# agents/shared/base_routes.py
# Import this into every agent's FastAPI app

from fastapi import FastAPI
from pydantic import BaseModel
import yaml, os

def mount_base_routes(app: FastAPI, life_plan_path: str = "life_plan.yaml"):
    """Every Hyper Agent gets these routes for free."""

    # Load life plan at startup
    with open(life_plan_path) as f:
        life_plan = yaml.safe_load(f)

    @app.get("/health")
    async def health():
        """🩺 Required — Healer Agent polls this every 30s."""
        return {"status": "alive", "agent": life_plan["identity_manifest"]["name"]}

    @app.get("/identity")
    async def identity():
        """📋 Returns full identity manifest from life_plan.yaml."""
        return life_plan["identity_manifest"]

    @app.get("/status")
    async def status():
        """📊 Returns runtime status for Mission Control dashboard."""
        return {
            "name":    life_plan["identity_manifest"]["name"],
            "version": life_plan["identity_manifest"]["version"],
            "state":   "running",
            "uptime":  get_uptime()
        }

    @app.post("/shutdown")
    async def shutdown():
        """🛑 Graceful shutdown — logs to governance ledger first."""
        await log_shutdown_event(life_plan["identity_manifest"]["name"])
        os._exit(0)
