import schedule
from feedback_api import ingest_feedback
from drift_detector import check_drift
from hitl import human_override_gate

def nightly_learning_cycle():
    # Step 1: Pull feedback from Redis queue
    feedback = ingest_feedback(source="redis://feedback-queue")
    
    # Step 2: Detect model drift
    drift_score = check_drift(feedback, threshold=0.15)
    if drift_score > 0.15:
        alert("⚠️ DRIFT DETECTED", severity="HIGH")
    
    # Step 3: Human gate before retrain
    if not human_override_gate.approved():
        return  # Wait for Lyndz to approve
    
    # Step 4: Retrain + version bump
    model.finetune(feedback)
    model.bump_version()
    model.push_to_registry("ghcr.io/welshdog/brain-agent")

schedule.every().day.at("02:00").do(nightly_learning_cycle)
